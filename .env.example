# Database
# Option 1: Use DATABASE_URL directly (from Neon, Supabase, etc.)
# Sign up at https://neon.tech, create a free database, copy the connection string
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/snowball?sslmode=require

# Option 2: Use individual params (for local Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=snowball
DB_USER=snowball
DB_PASS=snowball

# Security (change in production!)
SECRET_KEY=snowball-investment-secret-key-2026
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# User password (for production, set BORIS_PASSWORD in Render Dashboard)
# If not set, defaults to "Maelstormer5" for local development
# BORIS_PASSWORD=your_secure_password_here
